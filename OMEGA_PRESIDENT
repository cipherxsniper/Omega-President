def timestamp():
    return datetime.now().strftime("%Y-%m-%d %H:%M:%S")

def init_memory_file(file_path, default_data=None):
    if default_data is None:
        default_data = {}
    if not os.path.exists(file_path):
        with open(file_path, "w") as f:
            json.dump(default_data, f, indent=4)
        if DEBUG: print(f"[{timestamp()}] Created memory file: {file_path}")
    with open(file_path, "r") as f:
        try:
            data = json.load(f)
        except json.JSONDecodeError:
            data = default_data
            with open(file_path, "w") as f_write:
                json.dump(default_data, f_write, indent=4)
            if DEBUG: print(f"[{timestamp()}] Reset corrupted memory file: {file_path}")
    return data

